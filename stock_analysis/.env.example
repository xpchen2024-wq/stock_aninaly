# ============================================================================
# AI Stock Analysis Platform - Environment Configuration
# ============================================================================

# --- App ---
APP_NAME=AIStockAnalysis
APP_VERSION=1.4.0
APP_ENV=development
APP_DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://stock_user:stock_pass@localhost:5432/stock_analysis
DATABASE_URL_SYNC=postgresql://stock_user:stock_pass@localhost:5432/stock_analysis

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=60
REDIS_CONFIG_TTL=300

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Encryption (for API Keys) ---
ENCRYPTION_KEY=change-me-32-byte-key-for-aes256!

# --- AI Model Defaults ---
DEFAULT_LLM_PROVIDER=opencodezen
DEFAULT_LLM_MODEL=opencode/gpt-5.5
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenCode Zen (https://opencode.ai/zen - 官方精选模型网关)
# 登录 opencode.ai/zen 获取 API Key
OPENCODEZEN_API_KEY=zen-your-opencode-zen-api-key
OPENCODEZEN_BASE_URL=https://opencode.ai/zen/v1

# Optional: DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Tushare Token (optional) ---
TUSHARE_TOKEN=

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db

# --- Data Retention ---
NEWS_RETENTION_HOURS=72
KOL_OPINION_RETENTION_DAYS=30
KLINE_CACHE_DAYS=90

# --- Scheduling ---
HOT_TOPIC_UPDATE_INTERVAL_MINUTES=15
KOL_CRAWL_INTERVAL_MINUTES=30
REPORT_UPDATE_INTERVAL_HOURS=24

# --- Monitoring ---
ENABLE_METRICS=true
METRICS_PORT=9090

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
